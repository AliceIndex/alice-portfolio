---
// ここでデータをインポートしたり取得したりする
const title = "AliceIndex | Portfolio";
const skills = ["Go", "Docker", "Java (Forge/NeoForge)", "AWS/OCI", "Adobe Premiere Pro"];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans">
    
    <!-- Hero Section -->
    <header class="h-screen flex flex-col justify-center items-center text-center p-4">
      <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-blue-400 to-emerald-400 bg-clip-text text-transparent">
        AliceIndex
      </h1>
      <p class="text-xl text-gray-400 max-w-2xl">
        ソフトウェア開発とインフラ構築、そして動画制作を通じたアウトプットを行っています。
      </p>
    </header>

    <!-- Skills Section -->
    <section class="max-w-4xl mx-auto py-20 px-4">
      <h2 class="text-2xl font-bold mb-8 border-l-4 border-blue-500 pl-4">Tech Stack</h2>
      <div class="flex flex-wrap gap-3">
        {skills.map(skill => (
          <span class="bg-gray-800 px-4 py-2 rounded-full text-sm border border-gray-700">
            {skill}
          </span>
        ))}
      </div>
    </section>

    <!-- Featured Projects (簡易版) -->
    <section class="max-w-4xl mx-auto py-20 px-4">
      <h2 class="text-2xl font-bold mb-8 border-l-4 border-blue-500 pl-4">Featured Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 bg-gray-900 border border-gray-800 rounded-xl">
          <h3 class="text-xl font-bold mb-2">Focus Mixer</h3>
          <p class="text-gray-400 text-sm">Pomodoro Timer & Ambient Sound. Go / AWS / WebSocket.</p>
        </div>
        <div class="p-6 bg-gray-900 border border-gray-800 rounded-xl">
          <h3 class="text-xl font-bold mb-2">Minecraft Mod Development</h3>
          <p class="text-gray-400 text-sm">Java / Forge / NeoForge. v1.0.0 released.</p>
        </div>
      </div>
    </section>

  </body>
</html>